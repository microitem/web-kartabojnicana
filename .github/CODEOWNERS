/docs/devlog/           @IMPLEMENTER

# Kódová doména — implementer (VS Code)
/src/                   @IMPLEMENTER
/app/                   @IMPLEMENTER
/public/                @IMPLEMENTER
/package.json           @IMPLEMENTER
/package-lock.json      @IMPLEMENTER
/.github/workflows/     @IMPLEMENTER
